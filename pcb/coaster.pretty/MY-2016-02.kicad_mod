(footprint "MY-2016-02"
  (version 20240108)
  (generator "coaster")
  (descr "MYOUNG MY-2016-02 SMD CR2016 holder (LCSC C2979176). Land pattern from datasheet WD-CP-0081: two positive clip pads 5.6x1.75mm at 21.75mm center-to-center, central 10mm bare-copper negative contact (mask-defined, no paste). The physical part is much larger than its pads: a 22.8x15.2mm chamfered phosphor-bronze frame, 2.2mm tall, and the bare cell (O20mm) overhangs the frame on both depth sides. Body, cell outline, and courtyard reflect the true envelope; the referenced STEP body (frame box + cell cylinder) makes the part visible to CAD fit checks. The insertion mouth is on -X: leave that side clear for sliding the cell in and out, and verify holder orientation on the assembly preview.")
  (tags "CR2016 battery holder SMD")
  (attr smd)
  (layer "F.Cu")
  (property "Reference" "REF**" (at 0 -13.5 0) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
  (property "Value" "MY-2016-02" (at 0 13.5 0) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
  (pad "1" smd rect (at 0 -10.875) (size 5.6 1.75) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "1" smd rect (at 0 10.875) (size 5.6 1.75) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "2" smd circle (at 0 0) (size 10 10) (layers "F.Cu" "F.Mask"))
  (fp_circle (center 0 0) (end 10 0) (stroke (width 0.12) (type dash)) (fill none) (layer "F.Fab"))
  (fp_poly
    (pts (xy -3.6 -10.55) (xy 3.6 -10.55) (xy 7.6 -6.55) (xy 7.6 6.55) (xy 3.6 10.55)
         (xy -3.6 10.55) (xy -7.6 6.55) (xy -7.6 -6.55))
    (stroke (width 0.12) (type default)) (fill none) (layer "F.Fab"))
  (fp_rect (start -2.8 -11.4) (end 2.8 -10.55) (stroke (width 0.12) (type default)) (fill none) (layer "F.Fab"))
  (fp_rect (start -2.8 10.55) (end 2.8 11.4) (stroke (width 0.12) (type default)) (fill none) (layer "F.Fab"))
  (fp_text user "MOUTH" (at -6 0 90) (layer "F.Fab") (effects (font (size 0.8 0.8) (thickness 0.12))))
  (fp_poly
    (pts (xy -3.05 12) (xy -3.05 10.8) (xy -3.85 10.8) (xy -7.85 6.7) (xy -9.7 3.4)
         (xy -10.25 0) (xy -9.7 -3.4) (xy -7.85 -6.7) (xy -3.85 -10.8) (xy -3.05 -10.8)
         (xy -3.05 -12) (xy 3.05 -12) (xy 3.05 -10.8) (xy 3.85 -10.8) (xy 7.85 -6.7)
         (xy 9.7 -3.4) (xy 10.25 0) (xy 9.7 3.4) (xy 7.85 6.7) (xy 3.85 10.8)
         (xy 3.05 10.8) (xy 3.05 12))
    (stroke (width 0.05) (type default)) (fill none) (layer "F.CrtYd"))
  (fp_text user "CR2016" (at 0 5.8 0) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
  (fp_text user "+" (at -7 -9 0) (layer "F.SilkS") (effects (font (size 1.5 1.5) (thickness 0.3))))
  (model "${KIPRJMOD}/coaster.pretty/MY-2016-02.step"
    (offset (xyz 0 0 0))
    (scale (xyz 1 1 1))
    (rotate (xyz 0 0 0)))
)
