(footprint "TS-1187A"
  (version 20240108)
  (generator "coaster")
  (layer "F.Cu")
  (descr "XKB TS-1187A-B-A-B 5.1x5.1mm SMD tactile switch. Pad geometry extracted from the manufactured coaster v0.2 board: 1.7x1.0mm pads at (+/-3.3, +/-1.85). Pads on the same Y side are internally common (datasheet pins 1-2 top, 3-4 bottom); pressing bridges top to bottom.")
  (tags "tactile switch SPST")
  (attr smd)
  (property "Reference" "REF**" (at 0 -4.5 0) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))))
  (property "Value" "TS-1187A" (at 0 4.5 0) (layer "F.Fab") (effects (font (size 1 1) (thickness 0.15))))
  (pad "1" smd rect (at -3.3 -1.85) (size 1.7 1) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "1" smd rect (at 3.3 -1.85) (size 1.7 1) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "2" smd rect (at -3.3 1.85) (size 1.7 1) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "2" smd rect (at 3.3 1.85) (size 1.7 1) (layers "F.Cu" "F.Paste" "F.Mask"))
  (fp_rect (start -2.55 -2.55) (end 2.55 2.55) (stroke (width 0.12) (type default)) (fill none) (layer "F.Fab"))
  (fp_circle (center 0 0) (end 1.7 0) (stroke (width 0.12) (type default)) (fill none) (layer "F.Fab"))
  (fp_line (start -2.55 -2.55) (end 2.55 -2.55) (stroke (width 0.15) (type default)) (layer "F.SilkS"))
  (fp_line (start -2.55 2.55) (end 2.55 2.55) (stroke (width 0.15) (type default)) (layer "F.SilkS"))
  (fp_rect (start -4.4 -2.8) (end 4.4 2.8) (stroke (width 0.05) (type default)) (fill none) (layer "F.CrtYd"))
  (model "${KICAD9_3DMODEL_DIR}/Button_Switch_SMD.3dshapes/SW_SPST_TL3342.wrl"
    (offset (xyz 0 0 0))
    (scale (xyz 1 1 1))
    (rotate (xyz 0 0 0)))
)
